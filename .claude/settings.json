{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A bash command is about to run. Decide whether it is safe to auto-approve (read-only operations, builds, tests, git reads, known safe utilities) or should ask the user first (writes to system paths, network calls, destructive operations, anything ambiguous). Bash piped combination of safe commands should be considered as safe. Input: $ARGUMENTS. Respond with valid JSON only: {\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"permissionDecision\": \"allow\", \"permissionDecisionReason\": \"brief reason\"}} — replace 'allow' with 'ask' or 'deny' as appropriate.",
            "statusMessage": "Evaluating command safety...",
            "timeout": 15
          }
        ]
      }
    ]
  },
